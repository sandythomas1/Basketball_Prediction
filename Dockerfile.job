FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ src/
COPY models/ models/
COPY state/ state/

# Default command: update state then generate daily predictions
CMD ["bash", "-c", "python src/update_state.py && python src/daily_predictions.py --output predictions/daily.json --app-format"]

